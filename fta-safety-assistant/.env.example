# Copy this file to .env and fill in your values
# Never commit .env to version control

ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Voyage AI — used for semantic embeddings (free tier: 50M tokens/month)
# Get a key at https://dash.voyageai.com
VOYAGE_API_KEY=your_voyage_api_key_here

# Optional: Socrata app token for higher API rate limits
# Get one free at https://data.transportation.gov/profile/app_tokens
SOCRATA_APP_TOKEN=
